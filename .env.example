# --- Local: copy to .env.local ---
# --- Vercel: Project → Settings → Environment Variables ---
#    Add both for Production and Preview. Names must match exactly.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 服务端专用（Vercel / 本地勿提交）：Project Settings → API → service_role secret
# 可选；配置后结账在用户 JWT + RLS 失败时会用其重试写入（user_id 仍来自服务端会话，不信任前端）。
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase (dashboard) after deploy ---
# Authentication → URL Configuration:
#   Site URL: https://<your-vercel-app>.vercel.app  (and custom domain if any)
#   Redirect URLs: https://<your-vercel-app>.vercel.app/**
