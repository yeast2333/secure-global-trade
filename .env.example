# --- Local: copy to .env.local ---
# --- Vercel: Project → Settings → Environment Variables ---
#    Add both for Production and Preview. Names must match exactly.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (dashboard) after deploy ---
# Authentication → URL Configuration:
#   Site URL: https://<your-vercel-app>.vercel.app  (and custom domain if any)
#   Redirect URLs: https://<your-vercel-app>.vercel.app/**
