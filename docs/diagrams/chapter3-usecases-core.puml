actor "访客" as Guest #white
actor "注册用户" as Reg #white

rectangle "系统边界 · Secure Global Trade\n跨境 B2B 目录展销与安全演示平台" as SYS {

  usecase UC01 as "UC-01 浏览商品集合"
  usecase UC02 as "UC-02 关键字检索"
  usecase UC03 as "UC-03 类目筛选"
  usecase UC04 as "UC-04 查看商品详情"
  usecase UC05 as "UC-05 维护购物车"

  usecase UC06 as "UC-06 注册账号"
  usecase UC07 as "UC-07 登录"

  usecase UC08 as "UC-08 查看个人订单"
  usecase UC09 as "UC-09 结账生成订单"

  usecase UC10 as "UC-10 访问安全中心"
  usecase UC11 as "UC-11 触发速率限制演示"
}

Guest --> UC01
