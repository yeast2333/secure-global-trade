@startuml fullstack_three_tier_topology_simple
skinparam handwritten false
skinparam shadowing false
skinparam packageStyle rectangle
title 全栈三层拓扑（精简）

rectangle "第一层 · 表现层" as L1 #E3F2FD {
  artifact "Next.js 前端 · React · i18n · Supabase 客户端" as FE
}

rectangle "第二层 · 应用层" as L2 #E8F5E9 {
  artifact "Middleware + Route Handlers\n边缘安全 · 认证/结账 · Zod" as APP
}

rectangle "第三层 · 数据层" as L3 #FFF3E0 {
  database "Supabase\nPostgreSQL · Auth · RLS · REST/Realtime" as DB
}

FE -down-> APP : HTTPS（经本站）
APP -down-> DB : HTTPS + 服务端密钥
FE ..> DB : 按需直连

@enduml
